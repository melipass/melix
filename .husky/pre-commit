#!/usr/bin/env bash
# .husky/pre-commit
#
# Invoked by the global pre-commit hook (~/.config/git/hooks/pre-commit),
# which runs gitleaks first and then delegates here. No per-clone
# activation needed as long as the global core.hooksPath is set.
#
# For every staged file under assets/img/ or assets/video/:
#   - Videos: re-encode through bin/encode-video.sh (which downscales
#     to 720p, strips audio, sets faststart, wipes input metadata, and
#     tags the output so re-runs are idempotent).
#   - Images: strip identity-revealing metadata (EXIF, IPTC, XMP, GPS)
#     via exiftool, keeping the ICC color profile so colors stay right.
# Modified files are re-added so the commit captures the cleaned version.
# The pre-clean blobs briefly exist as unreachable git objects and get
# garbage-collected, so they never reach `origin`.
#
# Requires: exiftool, ffmpeg, ffprobe (see Brewfile — `brew bundle`).
#
# Compatible with bash 3.2 (the system bash on macOS).

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
PROTECTED_REGEX='^(assets/img/|assets/video/)'

# Read staged files (added/copied/modified/renamed) under protected paths.
staged=()
while IFS= read -r f; do
  [ -n "$f" ] && staged+=("$f")
done < <(
  git diff --cached --name-only --diff-filter=ACMR \
    | { grep -E "$PROTECTED_REGEX" || true; }
)

if [ ${#staged[@]} -eq 0 ]; then
  exit 0
fi

missing_tools=()
command -v exiftool >/dev/null 2>&1 || missing_tools+=("exiftool")
command -v ffmpeg   >/dev/null 2>&1 || missing_tools+=("ffmpeg")
command -v ffprobe  >/dev/null 2>&1 || missing_tools+=("ffprobe")

if [ ${#missing_tools[@]} -gt 0 ]; then
  cat >&2 <<ERR
Missing tools: ${missing_tools[*]}

This commit touches files under assets/img/ or assets/video/. The
pre-commit hook needs all of: exiftool, ffmpeg. Install them once with:

    brew bundle

Then retry the commit.
ERR
  exit 1
fi

# Case-insensitive extension matching (bash 3-friendly).
shopt -s nocasematch

processed=0
for f in "${staged[@]}"; do
  [ -f "$f" ] || continue
  case "$f" in
    *.mp4|*.mov|*.m4v|*.webm|*.avi|*.mkv)
      "$REPO_ROOT/bin/encode-video.sh" "$f"
      git add "$f"
      processed=$((processed + 1))
      ;;
    *.jpg|*.jpeg|*.png|*.webp|*.heic|*.tif|*.tiff|*.gif)
      printf 'stripping metadata: %s\n' "$f"
      # Wipe everything except the ICC color profile so screenshots and
      # photos keep accurate colors.
      exiftool -overwrite_original -all= --icc_profile:all= "$f" >/dev/null
      git add "$f"
      processed=$((processed + 1))
      ;;
    *.svg)
      # SVGs are XML — metadata lives in <metadata>, <title>, and <desc>
      # tags. Audit those by hand.
      ;;
  esac
done

shopt -u nocasematch

if [ "$processed" -gt 0 ]; then
  printf '%d file(s) processed and re-staged.\n' "$processed"
fi
exit 0
