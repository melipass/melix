# Tooling for working on melix.cl.
#
# Install everything in this file with:
#
#     brew bundle
#
# Re-run any time after pulling — `brew bundle` is idempotent and only
# installs what's missing.

# Jekyll runtime (Ruby is managed by rbenv; this is just the C build deps
# Jekyll-adjacent gems sometimes need).
brew "libyaml"

# Pre-commit hook: image metadata stripping.
brew "exiftool"

# Pre-commit hook + bin/encode-video.sh: video re-encoding.
brew "ffmpeg"
